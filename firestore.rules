
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rule for the medical documents collection
    match /medicalDocuments/{userId}/items/{itemId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read and write their own profile data
    match /users/{userId} {
      allow read, write, delete: if request.auth.uid == userId;

      // Allow users to manage their own subcollections
      match /appointments/{appointmentId} {
        allow read, write, delete: if request.auth.uid == userId;
      }

      match /medications/{medicationId} {
        allow read, write, delete: if request.auth.uid == userId;
      }

      match /documents/{documentId} {
        allow read, write, delete: if request.auth.uid == userId;
      }
    }

    match /alarms/{alarmId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId;
    }
  }
}
