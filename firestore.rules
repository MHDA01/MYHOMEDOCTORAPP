
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // ============================================
    // NUEVA ESTRUCTURA: Cuentas_Tutor / Integrantes
    // ============================================
    
    // Cuentas de Tutor (Hub Familiar)
    match /Cuentas_Tutor/{tutorId} {
      // Solo el tutor puede leer/escribir su cuenta
      allow read, write: if request.auth.uid == tutorId;
      
      // Subcolección de Integrantes (perfiles familiares)
      match /Integrantes/{integranteId} {
        // El tutor puede gestionar todos los integrantes de su familia
        allow read, write, delete: if request.auth.uid == tutorId;
      }
    }
    
    // ============================================
    // COLECCIONES LEGACY (mantener por compatibilidad)
    // ============================================
    
    // Usuarios (estructura antigua - solo lectura para migración)
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      
      match /{collection}/{docId} {
        allow read, write, delete: if request.auth.uid == userId;
      }
    }
    
    // Citas médicas
    match /appointments/{appointmentId} {
      allow read, write, delete: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // Sesiones de triaje
    match /app_triage_sessions/{sessionId} {
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // Logs de triaje (solo escritura para auditoría)
    match /triage_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if false; // Solo accesible por Cloud Functions
    }
    
    // Análisis médicos
    match /medicalAnalysis/{analysisId} {
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.doctorId == request.auth.uid);
      allow create: if request.auth != null;
    }
    
    // Alarmas (para notificaciones)
    match /alarms/{alarmId} {
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow read, delete: if false; // Solo Cloud Functions
    }
  }
}
