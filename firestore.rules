
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Allow users to read and write their own profile data
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      // Allow creating a new user document only if the ID matches the auth UID
      allow create: if request.auth.uid == userId;
      // Allow updating a user document only if the ID matches the auth UID and data is valid
      allow update: if request.auth.uid == userId && isValidUser(request.resource.data);
      
      // Allow users to manage their own subcollections
      match /appointments/{appointmentId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId && isValidAppointment(request.resource.data);
        allow update: if request.auth.uid == userId && isValidAppointment(request.resource.data);
        allow delete: if request.auth.uid == userId;
      }
      
      match /medications/{medicationId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId && isValidMedication(request.resource.data);
        allow update: if request.auth.uid == userId && isValidMedication(request.resource.data);
        allow delete: if request.auth.uid == userId;
      }
      
      match /documents/{documentId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId && isValidDocument(request.resource.data);
        allow update: if request.auth.uid == userId && isValidDocument(request.resource.data);
        allow delete: if request.auth.uid == userId;
      }
    }
    
    // Alarms can be created by authenticated users for themselves
    // and can be read/deleted by the system (via Cloud Functions)
    // Added validation for alarm data
    match /alarms/{alarmId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Cloud Functions (service account) bypass these rules.
      // No explicit read/delete for clients is needed as Functions handle it.
      // Allowing read and delete only if the authenticated user is the owner of the alarm
      allow read: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId;
    }
    
    // Data validation functions
    
    // Validate user data
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'firstName', 'lastName'])
          && data.email is string
          && data.firstName is string
          && data.lastName is string
          && data.email.size() > 0
          && data.firstName.size() > 0
          && data.lastName.size() > 0;
          // Add more validation rules for other user fields as needed
    }
    
    // Validate appointment data
    function isValidAppointment(data) {
      return data.keys().hasAll(['userId', 'date', 'time', 'type', 'notes'])
          && data.userId is string
          && data.date is string // Consider using a more appropriate type like timestamp
          && data.time is string // Consider using a more appropriate type
          && data.type is string
          && data.notes is string
          && data.userId == request.auth.uid; // Ensure appointment belongs to the authenticated user
          // Add more validation rules as needed
    }
    
    // Validate medication data
    function isValidMedication(data) {
      return data.keys().hasAll(['userId', 'name', 'dosage', 'frequency', 'startTime', 'endTime'])
          && data.userId is string
          && data.name is string
          && data.dosage is string
          && data.frequency is string
          && data.startTime is string // Consider using a more appropriate type
          && data.endTime is string // Consider using a more appropriate type
          && data.userId == request.auth.uid; // Ensure medication belongs to the authenticated user
          // Add more validation rules as needed
    }
    
    // Validate document data (adjust based on your document structure)
    function isValidDocument(data) {
      return data.keys().hasAll(['userId', 'name', 'fileUrl', 'uploadTime'])
          && data.userId is string
          && data.name is string
          && data.fileUrl is string
          && data.uploadTime is timestamp
          && data.userId == request.auth.uid; // Ensure document belongs to the authenticated user
          // Add more validation rules as needed
    }
  }
}
    }
  }
}
