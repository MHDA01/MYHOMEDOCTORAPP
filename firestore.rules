
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // HELPERS
    // ─────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────
    // ESTRUCTURA PRINCIPAL: Cuentas_Tutor
    // Cada tutor sólo puede leer/escribir su propio documento
    // y TODAS sus subcolecciones (Integrantes, historial,
    // Documentos, appointments, documents, medications).
    // ─────────────────────────────────────────────────────────
    match /Cuentas_Tutor/{tutorId} {
      allow read, write: if isOwner(tutorId);

      // Subcolecciones directas del tutor — profundidad 1
      // (appointments, documents, medications, etc.)
      match /{subcol}/{docId} {
        allow read, write, delete: if isOwner(tutorId);
      }

      // Perfiles familiares
      match /Integrantes/{integranteId} {
        allow read, write, delete: if isOwner(tutorId);

        // Cualquier sub-subcolección bajo un Integrante, a cualquier profundidad:
        //   historial/registro
        //   Documentos/{docId}
        //   orientaciones/{sessionId}
        //   orientaciones/{sessionId}/mensajes/{msgId}   ← nuevo
        match /{path=**} {
          allow read, write, delete: if isOwner(tutorId);
        }
      }
    }

    // ─────────────────────────────────────────────────────────
    // COLECCIONES LEGACY (solo compatibilidad transitoria)
    // Mantener hasta que se complete la migración de datos a
    // Cuentas_Tutor. Eliminar en la próxima versión mayor.
    // ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{collection}/{docId} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    // ─────────────────────────────────────────────────────────
    // SESIONES DE TRIAJE
    // ─────────────────────────────────────────────────────────
    match /app_triage_sessions/{sessionId} {
      allow read, write, delete: if isSignedIn() &&
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────
    // LOGS DE TRIAJE — solo Cloud Functions vía Admin SDK
    // ─────────────────────────────────────────────────────────
    match /triage_logs/{logId} {
      allow create: if isSignedIn();
      allow read, write, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // ALARMAS DE NOTIFICACIÓN — solo Cloud Functions vía Admin SDK
    // ─────────────────────────────────────────────────────────
    match /alarms/{alarmId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    // DENY ALL — bloque explícito de seguridad
    // Cualquier ruta no listada arriba queda DENEGADA.
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
